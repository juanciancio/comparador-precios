# --- Base de datos (Supabase managed) ---
# Connection string de Postgres. Usar la "Connection pooling" string de Supabase
# (Settings -> Database -> Connection string -> URI, modo "Transaction" o "Session").
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# --- Supabase (reservado para v2 / frontend; el scraper solo usa DATABASE_URL) ---
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Logging ---
# Niveles pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- User-Agent honesto (scraper) ---
# Se usa para armar: ComparadorPrecios/0.1 (+CONTACT_EMAIL)
CONTACT_EMAIL=contacto@dominio.com

# --- API HTTP (NestJS) ---
# 'production' habilita whitelist de CORS y desactiva pretty logs.
NODE_ENV=development
# Puerto del servidor HTTP de la API (3100: el 3000 colisiona con frontends / túnel SSH).
API_PORT=3100
# CORS: '*' refleja cualquier origen (dev). En prod, lista separada por comas:
# CORS_ORIGINS=https://app.midominio.com,https://www.midominio.com
CORS_ORIGINS=*
# Rate limiting por IP: RATE_LIMIT_LIMIT requests cada RATE_LIMIT_TTL segundos.
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
# Techos de outliers de GET /products/recent-changes (home de la PWA). Descartan
# productos con precio vigente > MAX_PRICE en cualquier cadena, o con |diff_pct|
# cross-retailer > MAX_DIFF_PCT. Ver CLAUDE.md -> "Reglas de recent-changes".
RECENT_CHANGES_MAX_PRICE=500000
RECENT_CHANGES_MAX_DIFF_PCT=200
