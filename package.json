{
  "name": "olavarria-comparador-precios",
  "version": "0.1.0",
  "description": "Comparador de precios entre supermercados argentinos (VTEX IO)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scrape": "tsx bin/scrape.ts",
    "report": "tsx bin/report.ts",
    "db:migrate": "tsx bin/migrate.ts",
    "smoke": "tsx bin/smoke-test.ts",
    "api:dev": "SWC_NODE_PROJECT=./tsconfig.api.json node --import @swc-node/register/esm-register --watch bin/serve-api.ts",
    "api:start": "SWC_NODE_PROJECT=./tsconfig.api.json node --import @swc-node/register/esm-register bin/serve-api.ts",
    "api:build": "tsc --noEmit -p tsconfig.api.json",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "p-limit": "^6.2.0",
    "pino": "^9.6.0",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "undici": "^7.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.7",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}
