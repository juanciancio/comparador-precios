{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,

    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "bin/**/*.ts", "tests/**/*.ts"],
  // src/api usa decoradores y su propia config (tsconfig.api.json). Se excluye
  // del typecheck base para no forzar experimentalDecorators/verbatimModuleSyntax
  // sobre el scraper. `pnpm api:build` cubre src/api. `tests/api` se excluye por
  // lo mismo: importa src/api, así que se typechea con tsconfig.api.json.
  "exclude": ["node_modules", "src/api", "bin/serve-api.ts", "tests/api"]
}
